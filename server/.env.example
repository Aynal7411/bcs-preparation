# === REQUIRED FOR PRODUCTION ===

# Environment
NODE_ENV=production
PORT=5000

# Database (REQUIRED)
# Use MongoDB Atlas for production: mongodb+srv://user:pass@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/job_prep?retryWrites=true&w=majority

# Client URL (REQUIRED for CORS)
CLIENT_URL=https://your-frontend.com
# Multiple URLs: comma-separated
# CLIENT_URLS=https://your-frontend.com,https://www.your-frontend.com

# JWT Secrets (REQUIRED - use strong random strings, min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-minimum-32-characters-long-and-random
JWT_EXPIRE=7d
REFRESH_JWT_SECRET=your-refresh-token-secret-key-minimum-32-characters-long-and-random
REFRESH_JWT_EXPIRE=30d

# Admin Credentials (REQUIRED - change immediately after first login)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=your-very-strong-admin-password-min-8-chars

# === OPTIONAL ===

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Service (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@yourcompany.com
